{
  "expo": {
    "name": "LUMEN",
    "slug": "lumen",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lumen",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E5D4F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.lumen.investor"
    },
    "android": {
      "package": "app.lumen.investor",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E5D4F"
      }
    },
    "web": { "bundler": "metro", "output": "static" },
    "plugins": ["expo-router", "expo-local-authentication", "expo-secure-store"],
    "experiments": { "typedRoutes": true },
    "extra": {
      "apiUrl": "https://expo-project-hub-1.preview.emergentagent.com"
    }
  }
}
